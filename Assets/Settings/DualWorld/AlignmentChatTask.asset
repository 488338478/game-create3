  m_Script: {fileID: 11500000, guid: 857037052abcd9f409bfc5960a8290bd, type: 3}
  m_Name: AlignmentChatTask
  m_EditorClassIdentifier: 
  taskId: alignment.right
  title: "\u8001\u677F\u7684\u6392\u7248\u9A8C\u6536"
  initialMessage:
    text: "\u6765\uFF0C\u628A\u5DE6\u8FB9\u90A3\u51E0\u4E2A\u6A21\u5757\u597D\u597D\u8BBE\u8BA1\u4E00\u4E0B\u6392\u7248\u3002\u6211\u76EF\u7740\u5462\uFF0C\u522B\u8BA9\u6211\u5931\u671B\u3002"
    sticker: {fileID: 0}
  highlightInitial: 0
  failureMessages:
  - text: "\u8FD9\u5C31\u662F\u4F60\u4EA4\u7684\uFF1F"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "\u8FD8\u662F\u4E0D\u5BF9\u3002\u6211\u8BF4\u7684\u8BDD\uFF0C\u4F60\u5230\u5E95\u6709\u6CA1\u6709\u542C\u8FDB\u53BB\u3002"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "\u5DE6\u8FB9\u90A3\u5757\u98D8\u7740\u5462\uFF0C\u4F60\u773C\u775B\u662F\u5E72\u4EC0\u4E48\u7528\u7684\u3002"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "\u5DEE\u8FDC\u4E86\u3002\u522B\u4EBA\u4E00\u904D\u5C31\u8FC7\uFF0C\u4F60\u8FD9\u90FD\u7B2C\u51E0\u904D\u4E86\u3002"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "\u91CD\u6765\u3002\u522B\u8DDF\u6211\u8BF4\u4F60\u5C3D\u529B\u4E86\uFF0C\u6211\u8981\u7684\u662F\u7ED3\u679C\u3002"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "\u51E0\u4E2A\u5757\u5404\u7AD9\u5404\u7684\uFF0C\u4E00\u770B\u5C31\u6CA1\u7528\u5FC3\u3002"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "\u5FC3\u91CC\u6CA1\u70B9\u6570\uFF1F\u53F3\u8FB9\u660E\u663E\u8FD8\u5DEE\u4E00\u622A\u3002"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "\u53C8\u51ED\u611F\u89C9\u662F\u5427\u3002\u804C\u573A\u91CC\u6CA1\u6709\u201C\u5DEE\u4E0D\u591A\u201D\u8FD9\u4E09\u4E2A\u5B57\u3002"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "\u8FD9\u7248\u8981\u662F\u53D1\u51FA\u53BB\uFF0C\u6211\u7684\u8138\u5F80\u54EA\u513F\u6401\u3002"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "\u6211\u5BF9\u4F60\u4E25\uFF0C\u662F\u8FD8\u89C9\u5F97\u4F60\u80FD\u505A\u597D\u3002\u522B\u8BA9\u6211\u770B\u8D70\u773C\u3002"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  successMessages:
  - text: "\u55EF\uFF0C\u8FD9\u7248\u8FD8\u884C\u3002"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "\u8FD9\u624D\u5BF9\u561B\u3002\u65E9\u8FD9\u6837\uFF0C\u4E0D\u5C31\u7701\u4E8B\u4E86\u3002"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "\u53EF\u4EE5\uFF0C\u53D1\u5427\u3002\u770B\uFF0C\u4F60\u4E0D\u662F\u505A\u4E0D\u5230\u3002"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "\u7A33\u4E86\u3002\u4E0B\u6B21\u522B\u7B49\u6211\u8BF4\u8FD9\u4E48\u591A\u904D\u3002"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "\u884C\uFF0C\u8FC7\u3002\u8FD9\u56DE\u603B\u7B97\u6CA1\u8BA9\u6211\u767D\u76EF\u7740\u3002"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "\u7EC8\u4E8E\u50CF\u6837\u4E86\uFF0C\u5B58\u4E00\u4E0B\u3002"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "\u8BB0\u4F4F\u8FD9\u611F\u89C9\u3002\u522B\u4E0B\u6B21\u53C8\u7ED9\u6211\u6253\u56DE\u539F\u5F62\u3002"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  playerSubmitLines:
  - "\u8001\u677F\uFF0C\u6211\u5148\u6392\u4E86\u4E00\u7248\uFF0C\u60A8\u770B\u770B\u3002"
  - "\u8FD9\u6B21\u5DE6\u8FB9\u548C\u4E2D\u95F4\u6211\u91CD\u65B0\u5BF9\u8FC7\u4E86\uFF0C\u5E94\u8BE5\u597D\u70B9\u4E86\u5427\uFF1F"
  - "\u6211\u53C8\u8C03\u4E86\u4E0B\u95F4\u8DDD\u2026\u2026\u73B0\u5728\u7A33\u4E00\u70B9\u4E86\u5417\uFF1F"
  - "\u53F3\u8FB9\u90A3\u5757\u6211\u6536\u56DE\u6765\u4E86\uFF0C\u60A8\u518D\u770B\u4E00\u773C\uFF1F"
  - "\u6211\u6309\u60A8\u8BF4\u7684\uFF0C\u628A\u91CD\u5FC3\u538B\u56DE\u6765\u4E86\u2026\u2026"
  - "\u8FD9\u7248\u6211\u771F\u7684\u5F88\u8BA4\u771F\uFF0C\u60A8\u770B\u80FD\u8FC7\u5417\uFF1F"
  - "\u8FB9\u7F18\u6211\u53C8\u5BF9\u4E86\u4E00\u904D\uFF0C\u5E94\u8BE5\u4E0D\u98D8\u4E86\u2026\u2026\u5427\u3002"
  - "\u8FD9\u6B21\u6211\u6CA1\u6562\u51ED\u611F\u89C9\uFF0C\u90FD\u662F\u7167\u7740\u7EBF\u8D34\u7684\u3002"
  - "\u6211\u2026\u2026\u6211\u5C3D\u529B\u4E86\uFF0C\u60A8\u518D\u770B\u770B\u597D\u4E0D\u597D\uFF1F"
  - "\u6700\u540E\u8FD9\u7248\uFF0C\u60A8\u5C31\u770B\u4E00\u773C\u2026\u2026"
  highlightFailure: 0
  highlightSuccess: 1
