%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 857037052abcd9f409bfc5960a8290bd, type: 3}
  m_Name: AlignmentChatTask
  m_EditorClassIdentifier:
  taskId: alignment.right
  title: "老板的排版验收"
  initialMessage:
    text: "来，把右边那几个模块按参考摆齐。我盯着呢，别让我失望。"
    sticker: {fileID: 0}
  highlightInitial: 0
  failureMessages:
  - text: "这就是你交的？"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "还是不对。我说的话，你到底有没有听进去。"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "左边那块飘着呢，你眼睛是干什么用的。"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "差远了。别人一遍就过，你这都第几遍了。"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "重来。别跟我说你尽力了，我要的是结果。"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "几个块各站各的，一看就没用心。"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "心里没点数？右边明显还差一截。"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "又凭感觉是吧。职场里没有“差不多”这三个字。"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  - text: "这版要是发出去，我的脸往哪儿搁。"
    sticker: {fileID: 21300000, guid: 26afbe578e54d9c44aed0c9787251f50, type: 3}
  - text: "我对你严，是还觉得你能做好。别让我看走眼。"
    sticker: {fileID: 21300000, guid: ae6c857d94eb30346be17075b630d170, type: 3}
  successMessages:
  - text: "嗯，这版还行。"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "这才对嘛。早这样，不就省事了。"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "可以，发吧。看，你不是做不到。"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "稳了。下次别等我说这么多遍。"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "行，过。这回总算没让我白盯着。"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  - text: "终于像样了，存一下。"
    sticker: {fileID: 21300000, guid: 2f8312bed5ef921429b792a4a6025919, type: 3}
  - text: "记住这感觉。别下次又给我打回原形。"
    sticker: {fileID: 21300000, guid: c5e9ae24759b4cd4099dfec781ad02d5, type: 3}
  playerSubmitLines:
  - "老板，我先排了一版，您看看。"
  - "这次左边和中间我重新对过了，应该好点了吧？"
  - "我又调了下间距……现在稳一点了吗？"
  - "右边那块我收回来了，您再看一眼？"
  - "我按您说的，把重心压回来了……"
  - "这版我真的很认真，您看能过吗？"
  - "边缘我又对了一遍，应该不飘了……吧。"
  - "这次我没敢凭感觉，都是照着线贴的。"
  - "我……我尽力了，您再看看好不好？"
  - "最后这版，您就看一眼……"
  highlightFailure: 0
  highlightSuccess: 1
